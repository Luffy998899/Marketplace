# ─────────────────────────────────────────────────────────────
# AI Character Marketplace — environment template
# Copy to .env and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development

# --- Persistence (optional) ---
# false = in-memory dev store (default). true = Postgres via Prisma.
USE_PRISMA=false

# --- Database (PostgreSQL via Prisma) ---
DATABASE_URL="postgresql://acm:acm@localhost:5432/acm?schema=public"

# --- Cache / sessions (Redis) ---
REDIS_URL="redis://localhost:6379"

# --- Search (Meilisearch) ---
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="dev_master_key_change_me"

# --- Object storage (S3 / Cloudflare R2) — signed, expiring URLs ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="auto"
S3_BUCKET="acm-assets"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
SIGNED_URL_TTL_SECONDS=300

# --- Auth ---
JWT_ACCESS_SECRET="change_me_access"
JWT_REFRESH_SECRET="change_me_refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
# Separate secret for signed asset download URLs (recommended in production)
ASSET_SIGNING_SECRET=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# --- API security ---
# Comma-separated allowed web origins (required in production)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# false in production — disables demo users, payment stubs, Google auth stub
ALLOW_DEV_STUBS=true

# --- Payments (dual gateway) — Phase 1 uses stubs; see docs/ASSUMPTIONS.md ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# --- API / Web wiring ---
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
# Toggle: web uses local mock data (Phase 1 default) vs live API
NEXT_PUBLIC_USE_MOCK_DATA=true

# --- Moderation ---
# true = listings go live instantly on submit (local dev default)
# false = listings stay IN_REVIEW until admin approves at /admin/moderation
MODERATION_AUTO_APPROVE=true

# Public URL for signed download links and uploaded asset URLs
API_PUBLIC_URL="http://localhost:4000"
